{
  "name": "remote-play-host-backend",
  "version": "1.0.0",
  "description": "Host-side application capturing desktop frame buffer/audio and simulating client inputs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.remoteplay.host",
    "productName": "RemotePlayHost",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.7.5"
  },
  "optionalDependencies": {
    "vigemclient": "^1.4.1"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
